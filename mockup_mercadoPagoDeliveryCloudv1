  <div class="modal-overlay" id="modalElegirTipo">
    <div class="modal">
      <h3 class="modal-title">¿Qué plataforma deseas conectar?</h3>
      <p class="modal-subtitle">Seleccioná la aplicación de Mercado Pago para iniciar la autorización OAuth.</p>
      <div class="modal-body">
        <select id="selectTipoMp" class="type-selector">
          <option value="MP">MercadoPago QR (Cobros en punto de venta)</option>
          <option value="MP_DELIVERY">MercadoPago Delivery (SmartPedidos)</option>
        </select>
      </div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="cerrarModal('modalElegirTipo')">Cancelar</button>
        <button class="btn-add" onclick="irAEscenarioCuenta()">Continuar →</button>
      </div>
    </div>
  </div>

  <!-- ============================================================ -->
  <!--  MODAL 2: Escenario de cuenta (shared userId vs nueva cuenta) -->
  <!-- ============================================================ -->
  <!--
    MODAL 2 — MOCKEO DE ESCENARIO DE CUENTA
    =========================================
    IMPORTANTE: Esta pantalla NO EXISTE en producción.
    En la realidad, el escenario (cuenta única o cuenta nueva) se determina automáticamente
    según el user_id que retorna Mercado Pago luego de que el usuario ingresa sus credenciales.
    Este modal es únicamente para simular ambos posibles resultados durante el desarrollo/mockup.
  -->
  <div class="modal-overlay" id="modalEscenarioCuenta">
    <div class="modal">
      <h3 class="modal-title">¿Cuál es el escenario de la cuenta?</h3>
      <p class="modal-subtitle" style="color: #c2185b; border: 1px dashed #c2185b; border-radius: 4px; padding: 6px 10px; background: #fff5f5;">
        ⓘ <strong>Pantalla de mockeo — no se implementa en producción.</strong><br>
        En el sistema real, este paso ocurre internamente: el <code>user_id</code> retornado por MP
        determina automáticamente si es una cuenta compartida o una cuenta nueva.
      </p>
      <div class="modal-body">
        <div class="scenario-cards">

          <!-- Escenario A: mismo userId compartido -->
          <div class="scenario-card selected" id="scenarioA" onclick="selectScenario('A')">
            <div class="scenario-card-title">
              Escenario A — Cuenta única compartida <span class="chip chip-shared">MÁS COMÚN</span>
            </div>
            <div class="scenario-card-desc">
              El franquiciado conecta <strong>la misma cuenta de Mercado Pago</strong> que ya usa para QR.
              El <code>user_id</code> y el <code>access_token</code> son <strong>idénticos</strong> para QR y Delivery.
              La fila existente se actualiza agregando el chip de la nueva app.
            </div>
          </div>

          <!-- Escenario B: nueva cuenta con nuevo userId -->
          <div class="scenario-card" id="scenarioB" onclick="selectScenario('B')">
            <div class="scenario-card-title">
              Escenario B — Nueva cuenta de MP <span class="chip chip-newaccount">CUENTA ADICIONAL</span>
            </div>
            <div class="scenario-card-desc">
              El franquiciado ingresa con <strong>una cuenta de Mercado Pago diferente</strong>, generando un nuevo
              <code>user_id</code> y un nuevo <code>access_token</code> exclusivo. Se crea una nueva fila independiente.
            </div>
          </div>

        </div>
        <div id="scenarioWarning" style="font-size: 0.78rem; color: #c2185b; display:none; margin-top: 8px;">
          ⚠️ En el Escenario B el sistema almacenará un segundo par <code>user_id / access_token</code> independiente del primero.
        </div>
      </div>
      <div class="modal-actions">
        <button class="btn-cancel" onclick="volverAModalTipo()">← Atrás</button>
        <button class="btn-add" onclick="iniciarMockLogin()">Continuar a MP →</button>
      </div>
    </div>
  </div>

  <!-- ============================================================ -->
  <!--  MODAL 3: Simulación OAuth / Login en MP                     -->
  <!-- ============================================================ -->
  <div class="modal-overlay" id="modalMockLogin">
    <div class="modal" style="text-align:center;">
      <h3 class="modal-title" style="color: var(--mp-blue);">Mercado Pago (Mock OAuth)</h3>
      <div class="modal-body">
        <div id="mockLoginAppInfo"
          style="background:#f0faff; border-radius:6px; padding:10px; margin-bottom:12px; font-size:0.8rem; text-align:left;">
        </div>
        <strong>El cliente se loguea en Mercado Pago para autorizar la aplicación.</strong><br><br>
        <small style="color:gray;">
          Simula la redirección hacia la pasarela de MP donde el usuario ingresa su cuenta y contraseña.
          MP retorna el <code>authorization_code</code> al Worker de Cloudflare (<code>automatizacionDeToken.js</code>),
          el cual intercambia el código por el <code>access_token</code> + <code>refresh_token</code> y
          los persiste en la DB de SmartCloud.
        </small>
      </div>
      <div class="modal-actions" style="justify-content: center;">
        <button class="btn-cancel" onclick="cerrarModal('modalMockLogin')">Cancelar</button>
        <button class="btn-add" style="background-color: var(--mp-blue);" onclick="finalizarLoginYAgregarRow()">
          Autorizar ("Aceptar en MP")
        </button>
      </div>
    </div>
  </div>


  <!-- ============================================================ -->
  <!--  SCRIPT PRINCIPAL                                            -->
  <!-- ============================================================ -->
  <script>
    // ============================================================
    // CONSTANTES DE APP IDs (REFERENCIA REAL)
    // ============================================================
    // ⚠️ NOTA DEVELOPER: Estos IDs determinan QUÉ aplicación de MP
    //    inicia el flujo OAuth. Son distintos pero pueden obtener
    //    tokens del MISMO user_id si el usuario tiene una sola cuenta.
    const APP_ID_QR = 'APP_ID_QR';          // Reemplazar con el client_id real de QR
    const APP_ID_DELIVERY = '2099696082787056';    // App ID de MercadoPago Delivery / SmartPedidos

    // ============================================================
    // ESTADO DEL MOCKUP
    // ============================================================
    let connectionsCount = 0;
    let currentTipoMp = 'MP';          // 'MP' | 'MP_DELIVERY'
    let currentScenario = 'A';           // 'A' (shared userId) | 'B' (nueva cuenta)

    // Usuario de la "cuenta principal" para simular el Escenario A
    // (reutilizado cuando QR ya conectó o cuando se confirma que es la misma cuenta)
    let sharedUserId = null;
    let sharedToken = null;

    // ============================================================
    // HELPERS DE UI
    // ============================================================
    function toggleTableVisibility() {
      const table = document.getElementById('tableConnections');
      const emptyState = document.getElementById('emptyState');
      if (connectionsCount > 0) {
        table.style.display = 'table';
        emptyState.style.display = 'none';
      } else {
        table.style.display = 'none';
        emptyState.style.display = 'block';
      }
    }

    function cerrarModal(id) {
      document.getElementById(id).style.display = 'none';
    }

    // ============================================================
    // FLUJO: Paso 1 — Elegir tipo de app (QR vs Delivery)
    // ============================================================
    function abrirModalTipoConexion() {
      document.getElementById('modalElegirTipo').style.display = 'flex';
    }

    // ============================================================
    // FLUJO: Paso 2 — Elegir escenario de cuenta
    // ============================================================
    function irAEscenarioCuenta() {
      currentTipoMp = document.getElementById('selectTipoMp').value;
      cerrarModal('modalElegirTipo');
      // Resetear selección
      selectScenario('A');
      document.getElementById('modalEscenarioCuenta').style.display = 'flex';
    }

    function volverAModalTipo() {
      cerrarModal('modalEscenarioCuenta');
      document.getElementById('modalElegirTipo').style.display = 'flex';
    }

    function selectScenario(scenario) {
      currentScenario = scenario;
      document.getElementById('scenarioA').classList.toggle('selected', scenario === 'A');
      document.getElementById('scenarioB').classList.toggle('selected', scenario === 'B');
      document.getElementById('scenarioWarning').style.display = scenario === 'B' ? 'block' : 'none';
    }

    // ============================================================
    // FLUJO: Paso 3 — Mock de login en MP
    // ============================================================
    function iniciarMockLogin() {
      cerrarModal('modalEscenarioCuenta');

      const appId = currentTipoMp === 'MP' ? APP_ID_QR : APP_ID_DELIVERY;
      const appLabel = currentTipoMp === 'MP' ? 'QR (Cobros)' : 'Delivery (SmartPedidos)';
      const scenarioLabel = currentScenario === 'A'
        ? '✅ Escenario A: Cuenta única — el mismo user_id/token se compartirá entre QR y Delivery'
        : '🆕 Escenario B: Nueva cuenta — se generará un nuevo user_id + access_token independiente';

      document.getElementById('mockLoginAppInfo').innerHTML = `
      <strong>App:</strong> ${appLabel}<br>
      <strong>App ID:</strong> <span style="font-family:monospace;">${appId}</span><br>
      <strong>Escenario:</strong> ${scenarioLabel}
    `;

      document.getElementById('modalMockLogin').style.display = 'flex';
    }

    // ============================================================
    // FLUJO: Resolución post-autorización y creación de fila
    // ============================================================
    function finalizarLoginYAgregarRow() {
      cerrarModal('modalMockLogin');

      const select = document.getElementById('selectTipoMp');
      const typeValue = currentTipoMp;
      const typeLabel = select.options[select.selectedIndex].text;
      const chipClass = typeValue === 'MP' ? 'chip-mp' : 'chip-mp-delivery';
      const appId = typeValue === 'MP' ? APP_ID_QR : APP_ID_DELIVERY;

      let mockedUserId, mockedToken;

      if (currentScenario === 'A') {
        // --------------------------------------------------------
        // ESCENARIO A: Cuenta única compartida
        // El mismo user_id/token aplica para QR y Delivery.
        // Si ya existe una fila con ese userId, solo agregamos el chip de la nueva app.
        // Si es la primera conexión, generamos el par y creamos la fila.
        // --------------------------------------------------------
        if (sharedUserId === null) {
          sharedUserId = Math.floor(Math.random() * 900000000) + 100000000;
          sharedToken = 'APP_USR-' + Math.random().toString(36).substring(2, 10).toUpperCase() + '-mock';
        }
        mockedUserId = sharedUserId;
        mockedToken = sharedToken;

        // Buscar si ya existe una fila para este userId (shared)
        const existingRow = document.getElementById('shared-row-' + mockedUserId);
        if (existingRow) {
          // Ya existe: solo agregamos el chip de la nueva app a la celda de Aplicación
          const appCell = existingRow.querySelector('td.app-cell');
          const newChip = document.createElement('span');
          newChip.className = 'chip ' + chipClass;
          newChip.style.marginLeft = '4px';
          newChip.textContent = typeLabel;
          appCell.appendChild(newChip);
          toggleTableVisibility();
          return; // No crear nueva fila
        }

        // Primera fila para este userId compartido
        connectionsCount++;
        const rowId = 'row-' + connectionsCount;
        const tr = document.createElement('tr');
        tr.id = 'shared-row-' + mockedUserId; // ID especial para localizarla luego

        tr.innerHTML = `
        <td class="app-cell"><span class="chip ${chipClass}">${typeLabel}</span></td>
        <td><strong>${mockedUserId}</strong></td>
        <td>
          <span class="token-display" id="token-hidden-${rowId}">•••••••••••••••••••••••••</span>
          <span class="token-display" id="token-visible-${rowId}" style="display:none; color: #2e7d32; font-weight:bold;">${mockedToken}</span>
        </td>
        <td style="text-align: right;">
          <div class="actions" style="justify-content: flex-end;">
            <button class="btn-icon" onclick="toggleTokenVisibility('${rowId}')" title="Mostrar/Ocultar Token">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
              </svg>
            </button>
            <button class="btn-disconnect" onclick="desconectarCuenta('${rowId}')">Desconectar</button>
          </div>
        </td>
      `;
        document.getElementById('tbodyConnections').appendChild(tr);

      } else {
        // --------------------------------------------------------
        // ESCENARIO B: Nueva cuenta con nuevo userId
        // Siempre genera un par completamente nuevo e independiente.
        // --------------------------------------------------------
        mockedUserId = Math.floor(Math.random() * 900000000) + 100000000;
        mockedToken = 'APP_USR-' + Math.random().toString(36).substring(2, 10).toUpperCase() + '-mock';

        connectionsCount++;
        const rowId = 'row-' + connectionsCount;
        const tr = document.createElement('tr');
        tr.id = rowId;

        tr.innerHTML = `
        <td class="app-cell">
          <span class="chip ${chipClass}">${typeLabel}</span>
          <span class="chip chip-newaccount" style="margin-left:4px;">cuenta nueva</span>
        </td>
        <td><strong>${mockedUserId}</strong></td>
        <td>
          <span class="token-display" id="token-hidden-${rowId}">•••••••••••••••••••••••••</span>
          <span class="token-display" id="token-visible-${rowId}" style="display:none; color: #2e7d32; font-weight:bold;">${mockedToken}</span>
        </td>
        <td style="text-align: right;">
          <div class="actions" style="justify-content: flex-end;">
            <button class="btn-icon" onclick="toggleTokenVisibility('${rowId}')" title="Mostrar/Ocultar Token">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 4.5C7 4.5 2.73 7.61 1 12c1.73 4.39 6 7.5 11 7.5s9.27-3.11 11-7.5c-1.73-4.39-6-7.5-11-7.5zM12 17c-2.76 0-5-2.24-5-5s2.24-5 5-5 5 2.24 5 5-2.24 5-5 5zm0-8c-1.66 0-3 1.34-3 3s1.34 3 3 3 3-1.34 3-3-1.34-3-3-3z"/>
              </svg>
            </button>
            <button class="btn-disconnect" onclick="desconectarCuenta('${rowId}')">Desconectar</button>
          </div>
        </td>
      `;
        document.getElementById('tbodyConnections').appendChild(tr);
      }

      toggleTableVisibility();
    }

    // ============================================================
    // FEATURE: Mostrar / ocultar token
    // ============================================================
    function toggleTokenVisibility(rowId) {
      const hiddenEl = document.getElementById(`token-hidden-${rowId}`);
      const visibleEl = document.getElementById(`token-visible-${rowId}`);
      if (hiddenEl.style.display !== 'none') {
        hiddenEl.style.display = 'none';
        visibleEl.style.display = 'inline';
      } else {
        hiddenEl.style.display = 'inline';
        visibleEl.style.display = 'none';
      }
    }

    // ============================================================
    // FEATURE: Desconectar cuenta
    // ============================================================
    function desconectarCuenta(rowId) {
      if (confirm('¿Estás seguro que deseas desconectar esta cuenta? Esto desvinculará esta sucursal de la operativa actual de Mercado Pago.')) {
        const row = document.getElementById(rowId);
        row.parentNode.removeChild(row);
        connectionsCount--;
        // Si se desconecta la última fila que usaba el userId compartido, lo limpiamos
        if (connectionsCount === 0) {
          sharedUserId = null;
          sharedToken = null;
        }
        toggleTableVisibility();
      }
    }
  </script>

</body>

</html>
