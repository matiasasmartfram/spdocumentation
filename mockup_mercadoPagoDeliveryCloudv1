<!DOCTYPE html>
<html lang="es" translate="no">

<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>SmartFran Cloud - Mercado Pago Multi Conexión</title>

  <link href="https://fonts.googleapis.com/css?family=Roboto:300,400,500,700&display=swap" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/@mudblazor/theme@latest/dist/mudblazor.min.css" rel="stylesheet">

  <style>
    :root {
      --mud-palette-primary: rgba(15, 0, 53, 1);
      --mud-palette-appbar-background: rgba(15, 0, 53, 1);
      --mud-palette-appbar-text: rgba(255, 255, 255, 1);
      --mud-palette-drawer-background: rgba(255, 255, 255, 1);
      --mp-blue: #009ee3;
      --mp-blue-dark: #0070a8;
    }

    body {
      margin: 0;
      padding: 0;
      font-family: 'Roboto', 'Helvetica', 'Arial', sans-serif;
      background-color: #f5f5f5;
    }

    .app-root {
      display: flex;
      flex-direction: column;
      height: 100vh;
      overflow: hidden;
    }

    .app-header {
      background-color: var(--mud-palette-primary);
      color: white;
      height: 64px;
      display: flex;
      align-items: center;
      padding: 0 16px;
      justify-content: space-between;
      box-shadow: 0px 3px 5px -1px rgba(0, 0, 0, 0.2);
      z-index: 1300;
      position: relative;
    }

    .header-logo {
      display: flex;
      align-items: center;
      gap: 8px;
      font-weight: 500;
      font-size: 1.25rem;
    }

    .header-right {
      display: flex;
      align-items: center;
      gap: 16px;
    }

    .header-user {
      display: flex;
      align-items: center;
      gap: 12px;
      font-size: 0.75rem;
      text-align: right;
    }

    .user-avatar {
      width: 40px;
      height: 40px;
      background-color: #9c27b0;
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: white;
      font-weight: 500;
      font-size: 14px;
    }

    .app-body {
      display: flex;
      flex: 1;
      height: calc(100vh - 64px);
    }

    .sidebar {
      width: 250px;
      background-color: white;
      border-right: 1px solid #e0e0e0;
      display: flex;
      flex-direction: column;
      overflow-y: auto;
      z-index: 1200;
    }

    .nav-item {
      display: flex;
      align-items: center;
      padding: 12px 16px;
      color: rgba(0, 0, 0, 0.87);
      font-size: 0.875rem;
      font-weight: 400;
      cursor: pointer;
    }

    .nav-item:hover {
      background-color: rgba(0, 0, 0, 0.04);
    }

    .nav-item.active {
      background-color: rgba(0, 0, 0, 0.08);
    }

    .nav-item svg {
      width: 24px;
      height: 24px;
      margin-right: 16px;
      fill: rgba(0, 0, 0, 0.54);
    }

    .nav-group {
      padding: 12px 16px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      color: rgba(0, 0, 0, 0.87);
      font-size: 0.875rem;
      font-weight: 500;
      cursor: pointer;
    }

    .nav-group-left {
      display: flex;
      align-items: center;
    }

    .nav-group svg {
      width: 24px;
      height: 24px;
      margin-right: 16px;
      fill: rgba(0, 0, 0, 0.54);
    }

    .nav-children {
      padding-left: 24px;
    }

    /* ---- MAIN CONTENT ---- */
    .main-content {
      flex: 1;
      background-color: #f5f5f5;
      display: flex;
      flex-direction: column;
      align-items: stretch;
      justify-content: flex-start;
      padding: 24px;
      overflow-y: auto;
      gap: 24px;
    }

    /* ---- PANEL GENERAL ---- */
    .connections-panel {
      background: white;
      border-radius: 8px;
      box-shadow: 0px 3px 5px -1px rgba(0, 0, 0, 0.2);
      padding: 24px;
      display: flex;
      flex-direction: column;
      gap: 16px;
    }

    .panel-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1px solid #e0e0e0;
      padding-bottom: 16px;
    }

    .panel-title {
      font-size: 1.25rem;
      font-weight: 500;
      margin: 0;
      color: var(--mud-palette-primary);
    }

    .btn-add {
      background-color: var(--mud-palette-primary);
      color: white;
      border: none;
      padding: 8px 16px;
      border-radius: 4px;
      font-weight: 500;
      font-size: 0.875rem;
      cursor: pointer;
      text-transform: uppercase;
      box-shadow: 0px 2px 4px rgba(0, 0, 0, 0.2);
      transition: background-color 0.2s;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .btn-add:hover {
      background-color: rgb(26, 0, 92);
    }

    /* ---- TABLA ---- */
    table.connections-table {
      width: 100%;
      border-collapse: collapse;
      text-align: left;
    }

    table.connections-table th,
    table.connections-table td {
      padding: 12px 16px;
      border-bottom: 1px solid #eee;
      font-size: 0.875rem;
      vertical-align: middle;
    }

    table.connections-table th {
      color: rgba(0, 0, 0, 0.6);
      font-weight: 500;
      text-transform: uppercase;
      font-size: 0.75rem;
    }

    /* ---- EMPTY STATE ---- */
    .empty-state {
      text-align: center;
      padding: 40px;
      color: rgba(0, 0, 0, 0.54);
    }

    .empty-state img {
      max-width: 200px;
      margin-bottom: 16px;
      opacity: 0.6;
    }

    /* ---- ACCIONES DE FILA ---- */
    .actions {
      display: flex;
      gap: 12px;
      align-items: center;
    }

    .btn-icon {
      background: none;
      border: none;
      cursor: pointer;
      color: rgba(0, 0, 0, 0.54);
      padding: 4px;
      border-radius: 4px;
      display: flex;
      align-items: center;
      justify-content: center;
      transition: background 0.2s, color 0.2s;
    }

    .btn-icon:hover {
      background: rgba(0, 0, 0, 0.05);
      color: rgba(0, 0, 0, 0.87);
    }

    .btn-disconnect {
      background: none;
      border: 1px solid #f44336;
      color: #f44336;
      padding: 4px 12px;
      border-radius: 4px;
      cursor: pointer;
      font-size: 0.75rem;
      font-weight: 500;
      text-transform: uppercase;
      transition: all 0.2s;
    }

    .btn-disconnect:hover {
      background: #f44336;
      color: white;
    }

    /* ---- MODALES ---- */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.5);
      z-index: 2000;
      display: none;
      align-items: center;
      justify-content: center;
    }

    .modal {
      background: white;
      border-radius: 8px;
      padding: 24px;
      width: 480px;
      max-width: 90%;
      box-shadow: 0px 11px 15px -7px rgba(0, 0, 0, 0.2), 0px 24px 38px 3px rgba(0, 0, 0, 0.14), 0px 9px 46px 8px rgba(0, 0, 0, 0.12);
    }

    .modal-title {
      font-size: 1.25rem;
      font-weight: 500;
      margin-top: 0;
      margin-bottom: 8px;
    }

    .modal-subtitle {
      font-size: 0.8rem;
      color: rgba(0, 0, 0, 0.5);
      margin-bottom: 20px;
    }

    .modal-body {
      margin-bottom: 24px;
      font-size: 0.875rem;
      color: rgba(0, 0, 0, 0.87);
    }

    .modal-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }

    .btn-cancel {
      background: none;
      border: none;
      padding: 8px 16px;
      cursor: pointer;
      font-weight: 500;
      color: rgba(0, 0, 0, 0.6);
      text-transform: uppercase;
    }

    .type-selector {
      width: 100%;
      padding: 10px;
      font-size: 1rem;
      border: 1px solid #ccc;
      border-radius: 4px;
      margin-top: 8px;
    }

    /* ---- CHIPS ---- */
    .chip {
      padding: 4px 8px;
      border-radius: 12px;
      font-size: 0.75rem;
      font-weight: 500;
      display: inline-block;
    }

    .chip-mp {
      background-color: #e3f2fd;
      color: #1976d2;
    }

    .chip-mp-delivery {
      background-color: #fce4ec;
      color: #c2185b;
    }

    .chip-shared {
      background-color: #e8f5e9;
      color: #2e7d32;
      font-size: 0.65rem;
      padding: 2px 6px;
      margin-left: 4px;
    }

    .chip-newaccount {
      background-color: #fff3e0;
      color: #e65100;
      font-size: 0.65rem;
      padding: 2px 6px;
      margin-left: 4px;
    }

    .token-display {
      font-family: monospace;
      letter-spacing: 1px;
    }

    /* ---- INFO BOX (panel de notas para developer) ---- */
    .dev-info-box {
      background: #fffde7;
      border-left: 4px solid #f9a825;
      border-radius: 4px;
      padding: 12px 16px;
      font-size: 0.8rem;
      color: rgba(0, 0, 0, 0.75);
      line-height: 1.6;
    }

    .dev-info-box strong {
      color: rgba(0, 0, 0, 0.87);
    }

    .dev-info-box code {
      background: #fff9c4;
      padding: 1px 5px;
      border-radius: 3px;
      font-size: 0.78rem;
    }

    /* ---- APP ID BADGE ---- */
    .appid-badge {
      display: inline-block;
      font-size: 0.7rem;
      font-family: monospace;
      color: #555;
      background: #f0f0f0;
      border-radius: 3px;
      padding: 1px 5px;
    }

    /* ---- SCENARIO CARDS en modal ---- */
    .scenario-cards {
      display: flex;
      flex-direction: column;
      gap: 10px;
      margin-bottom: 16px;
    }

    .scenario-card {
      border: 1px solid #e0e0e0;
      border-radius: 6px;
      padding: 12px 14px;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .scenario-card:hover {
      border-color: #009ee3;
      background: #f0faff;
    }

    .scenario-card.selected {
      border-color: #009ee3;
      background: #e3f5ff;
    }

    .scenario-card-title {
      font-weight: 500;
      font-size: 0.875rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .scenario-card-desc {
      font-size: 0.78rem;
      color: rgba(0, 0, 0, 0.55);
      line-height: 1.4;
    }

    /* ---- SHARED TOKEN BADGE en fila ---- */
    .shared-badge {
      display: flex;
      align-items: center;
      gap: 4px;
      flex-wrap: wrap;
    }

    /* ---- STEP INDICATOR ---- */
    .steps-indicator {
      display: flex;
      align-items: center;
      gap: 4px;
      margin-bottom: 16px;
      font-size: 0.75rem;
      color: rgba(0, 0, 0, 0.4);
    }

    .step {
      padding: 2px 8px;
      border-radius: 12px;
      background: #eee;
    }

    .step.active {
      background: var(--mud-palette-primary);
      color: white;
    }
  </style>
</head>

